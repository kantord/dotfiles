export default function GithubCard() {
  const items = useJSONStream("/usr/bin/bash", `while true; do \
    three_months_ago=$(date -d '3 months ago' +%Y-%m-%d); \
    five_weeks_ago=$(date -d '5 weeks ago' +%Y-%m-%d); \
    { gh search prs --author @me --state open --updated ">$three_months_ago" \
        {{ range (splitList "," .githubOrgList) }}--owner {{ . }} {{ end }}\
        --json repository,url --limit 100; \
      gh search prs --review-requested @me --state open --updated ">$three_months_ago" \
        {{ range (splitList "," .githubOrgList) }}--owner {{ . }} {{ end }}\
        --json repository,url --limit 100; \
      gh search issues --assignee @me --state open --updated ">$three_months_ago" \
        {{ range (splitList "," .githubOrgList) }}--owner {{ . }} {{ end }}\
        --json repository,url --limit 100; \
      gh search prs --merged --updated ">$five_weeks_ago" \
        {{ range (splitList "," .githubOrgList) }}--owner {{ . }} {{ end }}\
        --json repository --limit 100; \
    } | jq -cs '. as [$open_prs, $review_prs, $open_issues, $merged] | ($merged | [.[].repository.nameWithOwner] | unique) as $active | ([$open_prs[], $review_prs[], $open_issues[]] | unique_by(.url)) | group_by(.repository.nameWithOwner) | map(select(.[0].repository.nameWithOwner as $r | $active | index($r) != null)) | map({repo: .[0].repository.nameWithOwner, prs: [.[] | select(.url | test("/pull/"))] | length, issues: [.[] | select(.url | test("/issues/"))] | length}) | map(select(.prs > 0 or .issues > 0))'; \
    sleep 300; \
  done`) ?? [];

  if (items.length === 0) return null;

  const prStyle = {color: '#89b4fa'};
  const issueStyle = {color: '#f9e2af'};
  const dimStyle = {color: 'rgba(255,255,255,0.2)'};

  return (
    <container tw="flex flex-col gap-[4px] px-3 py-[8px]">
      <container tw="flex flex-row items-baseline">
        <text tw="flex-1 text-[10px] text-[rgba(255,255,255,0.5)]">GITHUB WIP</text>
        <text tw="w-[24px] text-right text-[8px] text-[rgba(255,255,255,0.3)]">PR</text>
        <text tw="w-[24px] text-right text-[8px] text-[rgba(255,255,255,0.3)]">tsk</text>
      </container>
      <Module bin="~/.local/bin/costae-github-open">
        {(_, events) => items.map(item => (
          <container tw="flex flex-row items-baseline">
            {(() => { const n = item.repo.split('/')[1]; return <text tw="flex-1 text-[11px] text-[rgba(255,255,255,0.75)]">{n.length > 22 ? n.slice(0, 21) + '…' : n}</text>; })()}
            <text tw="w-[24px] text-right text-[11px]" style={item.prs > 0 ? prStyle : dimStyle} on_click={item.prs > 0 ? Object.assign({}, events.open, {url: `https://github.com/${item.repo}/pulls?q=is%3Aopen+involves%3A%40me`}) : undefined}>{item.prs > 0 ? item.prs : '—'}</text>
            <text tw="w-[24px] text-right text-[11px]" style={item.issues > 0 ? issueStyle : dimStyle} on_click={item.issues > 0 ? Object.assign({}, events.open, {url: `https://github.com/${item.repo}/issues?q=is%3Aopen+assignee%3A%40me`}) : undefined}>{item.issues > 0 ? item.issues : '—'}</text>
          </container>
        ))}
      </Module>
    </container>
  );
}
