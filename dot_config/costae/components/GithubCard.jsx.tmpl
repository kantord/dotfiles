export default function GithubCard() {
  const data = useJSONStream("~/.local/bin/costae-github-data") ?? {};
  const items = data.wip ?? [];

  if (items.length === 0) return null;

  return (
    <container tw="flex flex-col gap-[4px] px-3 py-[8px]">
      <container tw="flex flex-row items-baseline">
        <text tw="flex-1 text-[10px] text-muted-foreground">GITHUB WIP</text>
        <text tw="w-[24px] text-right text-[8px] text-muted-foreground">PR</text>
        <text tw="w-[24px] text-right text-[8px] text-muted-foreground">tsk</text>
      </container>
      <Module bin="~/.local/bin/costae-github-open">
        {(_, events) => items.map(item => (
          <container tw="flex flex-row items-baseline">
            {(() => { const n = item.repo.split('/')[1]; return <text tw="flex-1 text-[11px] text-foreground">{n.length > 22 ? n.slice(0, 21) + '…' : n}</text>; })()}
            <text tw={`w-[24px] text-right text-[11px] ${item.prs > 0 ? "text-foreground" : "text-muted-foreground"}`} on_click={item.prs > 0 ? Object.assign({}, events.open, {url: `https://github.com/${item.repo}/pulls?q=is%3Aopen+author%3A%40me`}) : undefined}>{item.prs > 0 ? item.prs : '—'}</text>
            <text tw={`w-[24px] text-right text-[11px] ${item.issues > 0 ? "text-foreground" : "text-muted-foreground"}`} on_click={item.issues > 0 ? Object.assign({}, events.open, {url: `https://github.com/${item.repo}/issues?q=is%3Aopen+assignee%3A%40me`}) : undefined}>{item.issues > 0 ? item.issues : '—'}</text>
          </container>
        ))}
      </Module>
    </container>
  );
}
